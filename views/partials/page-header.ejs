<!-- Page Header Component -->
<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="<%- headerClass || 'bg-gradient-primary text-white py-4' %>">
        <div class="container">
          <div class="row align-items-center">
            <div class="col">
              <% if (headerIcon) { %>
              <div class="d-flex align-items-center">
                <div class="me-3">
                  <i class="<%- headerIcon %> fa-3x"></i>
                </div>
                <div>
                  <h1 class="h2 mb-1"><%- headerTitle %></h1>
                  <% if (headerSubtitle) { %>
                  <p class="mb-0 opacity-75"><%- headerSubtitle %></p>
                  <% } %>
                </div>
              </div>
              <% } else { %>
              <h1 class="h2 mb-1"><%- headerTitle %></h1>
              <% if (headerSubtitle) { %>
              <p class="mb-0 opacity-75"><%- headerSubtitle %></p>
              <% } %> <% } %>
            </div>
            <% if (headerActions) { %>
            <div class="col-auto"><%- headerActions %></div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
