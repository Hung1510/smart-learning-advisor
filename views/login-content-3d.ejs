<!-- Login Content — Three.js 3D background + glassmorphism card -->

<!-- Three.js fullscreen canvas (sits behind everything) -->
<canvas id="login-3d-canvas"></canvas>
<canvas id="login-3d-canvas2"></canvas>
<!-- Login card overlay -->
<div class="login-3d-overlay">
    <div class="login-3d-card">
        <!-- Logo / branding -->
        <div class="login-3d-brand">
            <div class="login-3d-icon-ring">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <h2 class="login-3d-title">Smart Learning</h2>
            <p class="login-3d-subtitle">Hệ thống tư vấn học tập thông minh — EIU</p>
        </div>

        <!-- Error alerts -->
        <% if (error) { %>
            <div class="login-3d-alert login-3d-alert-danger">
                <i class="fas fa-exclamation-triangle"></i>
                <%= error %>
            </div>
        <% } %>

        <%
        var errMap = {
            google:   'Đăng nhập Google thất bại.',
            no_email: 'Không lấy được email từ Google.',
            eiu_auth: 'Tài khoản Google này chưa được liên kết với AAO.',
            eiu_error:'Lỗi kết nối hệ thống EIU.'
        };
        var urlErr = errMap[locals.query && locals.query.err];
        %>
        <% if (urlErr) { %>
            <div class="login-3d-alert login-3d-alert-danger">
                <i class="fas fa-exclamation-triangle"></i>
                <%= urlErr %>
            </div>
        <% } %>

        <% if (locals.query && locals.query.mode === 'aao_password') { %>
            <!-- AAO password mode -->
            <div class="login-3d-alert login-3d-alert-info">
                <i class="fas fa-info-circle"></i>
                Lần đầu đăng nhập Google — vui lòng nhập mật khẩu AAO để liên kết.
            </div>
            <form action="/login-aao-password" method="POST" data-loading>
                <div class="login-3d-field">
                    <label for="password">
                        <i class="fas fa-lock"></i> Mật khẩu AAO
                    </label>
                    <input type="password" id="password" name="password" placeholder="Nhập mật khẩu AAO..." required autocomplete="current-password">
                </div>
                <button type="submit" class="login-3d-btn login-3d-btn-primary">
                    <i class="fas fa-link"></i>
                    <span>Liên kết tài khoản</span>
                </button>
            </form>
        <% } else { %>
            <!-- Normal login -->
            <form action="/login" method="POST" data-loading>
                <div class="login-3d-field">
                    <label for="studentId">
                        <i class="fas fa-id-card"></i> ID Sinh viên
                    </label>
                    <input type="text" id="studentId" name="studentId" placeholder="Nhập mã sinh viên..." required autocomplete="username">
                </div>
                <div class="login-3d-field">
                    <label for="password">
                        <i class="fas fa-lock"></i> Mật khẩu
                    </label>
                    <input type="password" id="password" name="password" placeholder="Nhập mật khẩu..." required autocomplete="current-password">
                </div>
                <button type="submit" class="login-3d-btn login-3d-btn-primary">
                    <i class="fas fa-sign-in-alt"></i>
                    <span>Đăng nhập</span>
                </button>
            </form>

            <div class="login-3d-divider">
                <span>hoặc</span>
            </div>

            <a href="/auth/google" class="login-3d-btn login-3d-btn-google">
                <svg width="18" height="18" viewBox="0 0 48 48">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                </svg>
                <span>Đăng nhập bằng Google (EIU)</span>
            </a>
        <% } %>

        <div class="login-3d-footer">
            &copy; 2025 EIU Smart Learning Advisor
        </div>
    </div>
</div>
