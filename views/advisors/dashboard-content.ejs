<!-- Welcome Banner -->
<div class="card bg-gradient-primary text-white mb-4 shadow-sm border-0">
  <div class="card-body d-flex justify-content-between align-items-center">
    <div>
      <h4 class="mb-1">Xin chào, <%= advisor.name %>!</h4>
      <p class="mb-0">Chào mừng bạn đến với Hệ thống Cố vấn học tập EIU</p>
    </div>
    <div>
      <i class="fas fa-chalkboard-teacher fa-3x"></i>
    </div>
  </div>
</div>

<!-- Dashboard Quick Stats -->
<div class="row text-center">
  <div class="col-md-3 mb-3 d-flex">
    <div class="card flex-fill shadow-sm border-0">
      <div class="card-body d-flex flex-column justify-content-around">
        <i class="fas fa-user-graduate fa-2x text-primary mb-2"></i>
        <h6 class="fw-bold">Số sinh viên quản lý</h6>
        <h5>--</h5>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-3 d-flex">
    <div class="card flex-fill shadow-sm border-0">
      <div class="card-body d-flex flex-column justify-content-around">
        <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
        <h6 class="fw-bold">Số sinh viên tốt nghiệp</h6>
        <h5>--</h5>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-3 d-flex">
    <div class="card flex-fill shadow-sm border-0">
      <div class="card-body d-flex flex-column justify-content-around">
        <i class="fas fa-chart-line fa-2x text-warning mb-2"></i>
        <h6 class="fw-bold">Báo cáo gần đây</h6>
        <h5>--</h5>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-3 d-flex">
    <div class="card flex-fill shadow-sm border-0">
      <div class="card-body d-flex flex-column justify-content-around">
        <i class="fas fa-calendar fa-2x text-info mb-2"></i>
        <h6 class="fw-bold">Ngày tham gia</h6>
        <h5>--</h5>
      </div>
    </div>
  </div>
</div>

<!-- Advisor Information + Quick Actions -->
<div class="row">
  <div class="col-md-6 d-flex">
    <div class="card flex-fill shadow-sm border-0">
      <div class="card-header bg-light fw-bold">
        <i class="fas fa-user me-2"></i> Thông tin cố vấn
      </div>
      <div class="card-body d-flex flex-column justify-content-between">
        <div>
          <p><strong>Họ tên:</strong> <%= advisor.name %></p>
          <p><strong>Mã số:</strong> --</p>
          <p><strong>Email:</strong> --</p>
          <p><strong>Vai trò:</strong> Cố vấn học tập</p>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-6 d-flex">
    <div class="card flex-fill shadow-sm border-0">
      <div class="card-header bg-light fw-bold">
        <i class="fas fa-bolt me-2"></i> Hành động nhanh
      </div>
      <div class="card-body d-flex flex-column justify-content-around">
        <div class="d-grid gap-3">
          <a href="/advisor/students" class="btn btn-outline-primary text-start">
            <i class="fas fa-user-graduate me-2"></i> Danh sách sinh viên
          </a>
          <a href="/advisor/reports" class="btn btn-outline-warning text-start">
            <i class="fas fa-chart-bar me-2"></i> Báo cáo học tập
          </a>
          <a href="#" class="btn btn-outline-success text-start disabled">
            <i class="fas fa-comments me-2"></i> Giao tiếp với sinh viên (work in progress)
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../advisors/partials/footer') %>