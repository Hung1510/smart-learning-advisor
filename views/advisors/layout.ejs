<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%- title || 'Smart Learning Advisor - Advisor' %></title>
  <meta name="description" content="<%- description || '' %>"/>

  <!-- CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet"/>
  <link href="/css/style.css" rel="stylesheet"/>

  <% if (pageStyles) { %>
    <%- pageStyles %>
  <% } %>
</head>

<body class="<%- bodyClass || '' %>">

  <!-- Navigation (only show if not login page) -->
  <% if (!hideNavigation) { %>
    <%- include('../advisors/partials/navigation') %>
  <% } %>

  <main class="<%- mainClass || 'min-vh-100' %>">

    <!-- Page Header (optional) -->
    <% if (typeof pageHeader !== 'undefined') { %>
      <div class="page-header">
        <%- pageHeader %>
      </div>
    <% } else { %>
      <%- include('../advisors/partials/page-header') %>
    <% } %>

    <!-- Breadcrumb (optional) -->
    <% if (breadcrumb && Array.isArray(breadcrumb) && breadcrumb.length > 0) { %>
      <div class="container mt-3">
        <%- include('../advisors/partials/breadcrumb', { breadcrumb }) %>
      </div>
    <% } %>

    <!-- Page Content -->
    <div class="container mt-4">
      <%- body %>
    </div>

  </main>

  <!-- Footer (optional) -->
  <% if (showFooter) { %>
    <%- include('../advisors/partials/footer') %>
  <% } %>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

  <% if (pageScripts) { %>
    <%- pageScripts %>
  <% } %>

</body>
</html>
