<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!--  PRIMARY SEO  -->
  <title>Smart Learning Advisor — Tư vấn học tập thông minh cho sinh viên EIU</title>
  <meta name="description" content="Smart Learning Advisor: cố vấn học tập thông minh dùng AI cho sinh viên EIU. Xem điểm, theo dõi GPA, nhận lộ trình môn học và lời khuyên học tập cá nhân hóa miễn phí." />
  <meta name="keywords" content="smart learning advisor, tư vấn học tập thông minh, cố vấn học tập, student advisor, tư vấn AI, xem điểm sinh viên, GPA, lộ trình học tập, EIU, Eastern International University, học tập" />
  <meta name="author" content="EIU" />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="theme-color" content="#0d6efd" />
  <meta name="language" content="Vietnamese" />
  <link rel="canonical" href="<%= siteUrl %>/" />

  <!--  OPEN GRAPH  -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Smart Learning Advisor" />
  <meta property="og:title" content="Smart Learning Advisor — Tư vấn học tập thông minh cho sinh viên EIU" />
  <meta property="og:description" content="Cố vấn học tập AI cho sinh viên EIU: xem điểm, theo dõi GPA, lộ trình môn học và lời khuyên học tập cá nhân hóa." />
  <meta property="og:url" content="<%= siteUrl %>/" />
  <meta property="og:image" content="<%= siteUrl %>/img/og-image.png" />
  <meta property="og:locale" content="vi_VN" />

  <!--  TWITTER  -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Smart Learning Advisor — Tư vấn học tập thông minh cho sinh viên EIU" />
  <meta name="twitter:description" content="Cố vấn học tập AI cho sinh viên EIU: xem điểm, GPA, lộ trình môn học và lời khuyên cá nhân hóa." />
  <meta name="twitter:image" content="<%= siteUrl %>/img/og-image.png" />

  <link rel="icon" href="/img/logo.png" />
  <link rel="apple-touch-icon" href="/img/logo.png" />
  <link rel="manifest" href="/manifest.json" />

  <!--  STRUCTURED DATA (JSON-LD)  -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Smart Learning Advisor",
    "alternateName": "Cố vấn học tập thông minh EIU",
    "url": "<%= siteUrl %>/",
    "applicationCategory": "EducationApplication",
    "operatingSystem": "Web",
    "inLanguage": "vi",
    "description": "Cố vấn học tập thông minh dùng AI cho sinh viên EIU: xem điểm, theo dõi GPA, lộ trình môn học và lời khuyên học tập cá nhân hóa.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "VND" },
    "featureList": [
      "Xem điểm và bảng điểm chi tiết",
      "Theo dõi và tính GPA",
      "Tư vấn học tập bằng AI",
      "Lộ trình môn học theo chuyên ngành",
      "Kết nối với cố vấn học tập"
    ],
    "publisher": {
      "@type": "EducationalOrganization",
      "name": "Eastern International University",
      "alternateName": "EIU"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Smart Learning Advisor là gì?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Smart Learning Advisor là hệ thống cố vấn học tập thông minh cho sinh viên EIU. Ứng dụng giúp xem điểm, theo dõi GPA, gợi ý lộ trình môn học và đưa ra lời khuyên học tập cá nhân hóa bằng AI."
        }
      },
      {
        "@type": "Question",
        "name": "Ai có thể sử dụng Smart Learning Advisor?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sinh viên Eastern International University (EIU) đăng nhập bằng tài khoản sinh viên hoặc Google để xem điểm, GPA và nhận tư vấn học tập."
        }
      },
      {
        "@type": "Question",
        "name": "Ứng dụng có tính phí không?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Không. Smart Learning Advisor là dự án miễn phí dành cho sinh viên EIU."
        }
      },
      {
        "@type": "Question",
        "name": "Tư vấn AI hoạt động như thế nào?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Hệ thống phân tích bảng điểm, GPA và lộ trình môn học của bạn, sau đó đưa ra gợi ý môn nên học và lời khuyên cải thiện kết quả học tập."
        }
      }
    ]
  }
  </script>

  <style>
    :root {
      --blue: #0d6efd;
      --blue-dark: #0a58ca;
      --ink: #0b1b34;
      --muted: #5b6b82;
      --bg: #f6f9ff;
      --card: #ffffff;
      --line: #e3ebf7;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      color: var(--ink);
      background: var(--bg);
      line-height: 1.6;
    }
    a { color: var(--blue); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .wrap { max-width: 1080px; margin: 0 auto; padding: 0 20px; }

    header.site {
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 0; position: sticky; top: 0; z-index: 10;
      background: rgba(246,249,255,.85); backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--line);
    }
    .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 1.05rem; }
    .brand img { width: 32px; height: 32px; border-radius: 6px; }
    .btn {
      display: inline-block; padding: 10px 20px; border-radius: 10px;
      font-weight: 600; border: 1px solid transparent; cursor: pointer;
    }
    .btn-primary { background: var(--blue); color: #fff; }
    .btn-primary:hover { background: var(--blue-dark); text-decoration: none; }
    .btn-ghost { border-color: var(--line); color: var(--ink); background: #fff; }
    .btn-ghost:hover { border-color: var(--blue); text-decoration: none; }

    .hero { padding: 72px 0 48px; text-align: center; }
    .eyebrow {
      display: inline-block; font-size: .8rem; font-weight: 700; letter-spacing: .08em;
      text-transform: uppercase; color: var(--blue); background: #e7f0ff;
      padding: 6px 14px; border-radius: 999px; margin-bottom: 20px;
    }
    .hero h1 { font-size: clamp(2rem, 5vw, 3.1rem); line-height: 1.15; margin: 0 0 16px; letter-spacing: -.02em; }
    .hero p.lead { font-size: 1.18rem; color: var(--muted); max-width: 680px; margin: 0 auto 28px; }
    .hero .cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

    .section { padding: 56px 0; }
    .section h2 { font-size: clamp(1.5rem, 3.5vw, 2.1rem); text-align: center; margin: 0 0 8px; letter-spacing: -.01em; }
    .section .sub { text-align: center; color: var(--muted); max-width: 620px; margin: 0 auto 36px; }

    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; }
    .card {
      background: var(--card); border: 1px solid var(--line); border-radius: 16px;
      padding: 26px 22px;
    }
    .card .ic {
      width: 44px; height: 44px; border-radius: 11px; background: #e7f0ff; color: var(--blue);
      display: grid; place-items: center; font-size: 1.3rem; margin-bottom: 14px; font-weight: 700;
    }
    .card h3 { margin: 0 0 8px; font-size: 1.15rem; }
    .card p { margin: 0; color: var(--muted); font-size: .98rem; }

    .steps { counter-reset: step; max-width: 760px; margin: 0 auto; display: grid; gap: 16px; }
    .step { display: flex; gap: 16px; align-items: flex-start; background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 20px; }
    .step::before {
      counter-increment: step; content: counter(step);
      flex: 0 0 36px; width: 36px; height: 36px; border-radius: 50%;
      background: var(--blue); color: #fff; font-weight: 700; display: grid; place-items: center;
    }
    .step h3 { margin: 0 0 4px; font-size: 1.05rem; }
    .step p { margin: 0; color: var(--muted); }

    details.faq {
      background: #fff; border: 1px solid var(--line); border-radius: 12px;
      padding: 16px 20px; margin-bottom: 12px; max-width: 760px; margin-left: auto; margin-right: auto;
    }
    details.faq summary { font-weight: 600; cursor: pointer; list-style: none; }
    details.faq summary::-webkit-details-marker { display: none; }
    details.faq summary::after { content: "+"; float: right; color: var(--blue); font-weight: 700; }
    details.faq[open] summary::after { content: "−"; }
    details.faq p { color: var(--muted); margin: 12px 0 0; }

    .cta-band {
      background: linear-gradient(135deg, var(--blue), var(--blue-dark));
      color: #fff; border-radius: 20px; padding: 48px 24px; text-align: center; margin: 24px 0;
    }
    .cta-band h2 { color: #fff; }
    .cta-band p { color: #dce8ff; max-width: 560px; margin: 0 auto 24px; }
    .cta-band .btn-primary { background: #fff; color: var(--blue); }
    .cta-band .btn-primary:hover { background: #eef4ff; }

    footer.site { border-top: 1px solid var(--line); padding: 32px 0; color: var(--muted); font-size: .92rem; }
    footer.site .row { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; }

    @media (max-width: 560px) {
      .hero { padding: 48px 0 32px; }
      header.site .btn-ghost { display: none; }
    }
  </style>
</head>

<body>
  <header class="site">
    <div class="wrap" style="display:flex;align-items:center;justify-content:space-between;width:100%;">
      <a class="brand" href="/" aria-label="Smart Learning Advisor">
        <img src="/img/logo.png" alt="Smart Learning Advisor logo" />
        <span>Smart Learning Advisor</span>
      </a>
      <nav style="display:flex;gap:10px;align-items:center;">
        <a class="btn btn-ghost" href="#tinh-nang">Tính năng</a>
        <a class="btn btn-primary" href="/login">Đăng nhập</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="wrap">
        <span class="eyebrow">Dành cho sinh viên EIU</span>
        <h1>Tư vấn học tập thông minh<br />cho sinh viên EIU</h1>
        <p class="lead">
          Smart Learning Advisor là cố vấn học tập dùng AI giúp bạn xem điểm, theo dõi GPA,
          lập lộ trình môn học và nhận lời khuyên học tập cá nhân hóa — tất cả ở một nơi.
        </p>
        <div class="cta">
          <a class="btn btn-primary" href="/login">Bắt đầu ngay</a>
          <a class="btn btn-ghost" href="#tinh-nang">Xem tính năng</a>
        </div>
      </div>
    </section>

    <section class="section" id="tinh-nang">
      <div class="wrap">
        <h2>Mọi thứ bạn cần để học tốt hơn</h2>
        <p class="sub">Một công cụ tư vấn học tập gọn nhẹ, miễn phí, xây riêng cho sinh viên Eastern International University.</p>
        <div class="grid">
          <article class="card">
            <div class="ic">📊</div>
            <h3>Xem điểm &amp; GPA</h3>
            <p>Bảng điểm chi tiết theo từng năm học và học kỳ, tự động tính GPA tích lũy của bạn.</p>
          </article>
          <article class="card">
            <div class="ic">🤖</div>
            <h3>Tư vấn AI cá nhân hóa</h3>
            <p>Đặt câu hỏi về việc học, nhập mục tiêu và khó khăn — AI phân tích và đưa ra lời khuyên cụ thể.</p>
          </article>
          <article class="card">
            <div class="ic">🗺️</div>
            <h3>Lộ trình môn học</h3>
            <p>Sơ đồ môn học theo chuyên ngành, gợi ý môn nên đăng ký dựa trên những gì bạn đã hoàn thành.</p>
          </article>
          <article class="card">
            <div class="ic">🎓</div>
            <h3>Kết nối cố vấn</h3>
            <p>Nhắn tin và trao đổi trực tiếp với cố vấn học tập để được đồng hành suốt quá trình học.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section" style="background:#fff;border-top:1px solid var(--line);border-bottom:1px solid var(--line);">
      <div class="wrap">
        <h2>Cách hoạt động</h2>
        <p class="sub">Ba bước để nhận tư vấn học tập thông minh.</p>
        <div class="steps">
          <div class="step">
            <div>
              <h3>Đăng nhập</h3>
              <p>Dùng tài khoản sinh viên EIU hoặc đăng nhập bằng Google.</p>
            </div>
          </div>
          <div class="step">
            <div>
              <h3>Xem kết quả học tập</h3>
              <p>Hệ thống tải bảng điểm, tính GPA và dựng lộ trình môn học của bạn.</p>
            </div>
          </div>
          <div class="step">
            <div>
              <h3>Nhận tư vấn AI</h3>
              <p>Nhập mục tiêu và khó khăn, AI đưa ra lời khuyên và môn học nên ưu tiên.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="wrap">
        <h2>Câu hỏi thường gặp</h2>
        <p class="sub">Những điều sinh viên hay hỏi về Smart Learning Advisor.</p>
        <details class="faq" open>
          <summary>Smart Learning Advisor là gì?</summary>
          <p>Là hệ thống cố vấn học tập thông minh cho sinh viên EIU: xem điểm, theo dõi GPA, gợi ý lộ trình môn học và đưa ra lời khuyên học tập cá nhân hóa bằng AI.</p>
        </details>
        <details class="faq">
          <summary>Ai có thể sử dụng?</summary>
          <p>Sinh viên Eastern International University (EIU) đăng nhập bằng tài khoản sinh viên hoặc Google.</p>
        </details>
        <details class="faq">
          <summary>Ứng dụng có tính phí không?</summary>
          <p>Không. Đây là dự án miễn phí dành cho sinh viên EIU.</p>
        </details>
        <details class="faq">
          <summary>Tư vấn AI hoạt động thế nào?</summary>
          <p>AI phân tích bảng điểm, GPA và lộ trình môn học của bạn, sau đó gợi ý môn nên học và cách cải thiện kết quả.</p>
        </details>
      </div>
    </section>

    <section class="section">
      <div class="wrap">
        <div class="cta-band">
          <h2>Sẵn sàng học thông minh hơn?</h2>
          <p>Đăng nhập và nhận lộ trình học tập cùng tư vấn AI cá nhân hóa ngay hôm nay.</p>
          <a class="btn btn-primary" href="/login">Đăng nhập ngay</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site">
    <div class="wrap">
      <div class="row">
        <div>© <%= new Date().getFullYear() %> Smart Learning Advisor — dự án dành cho sinh viên EIU.</div>
        <div><a href="/login">Đăng nhập</a> · <a href="#tinh-nang">Tính năng</a></div>
      </div>
    </div>
  </footer>
</body>
</html>
