<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- title || 'Smart Learning Advisor' %></title>
    <meta name="description" content="<%- description || 'Hệ thống tư vấn học tập thông minh cho sinh viên EIU' %>">

    <%# All layout pages are auth-gated -> noindex. Public indexing is handled by views/landing.ejs %>
    <meta name="robots" content="noindex, follow">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Smart Learning Advisor">
    <meta property="og:title" content="<%- title || 'Smart Learning Advisor' %>">
    <meta property="og:description" content="<%- description || 'Hệ thống tư vấn học tập thông minh cho sinh viên EIU' %>">
    <meta property="og:image" content="<%- (typeof siteUrl !== 'undefined' ? siteUrl : '') %>/img/og-image.png">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:image" content="<%- (typeof siteUrl !== 'undefined' ? siteUrl : '') %>/img/og-image.png">

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/img/logo.png">
    <link rel="apple-touch-icon" href="/img/logo3.png">
    <meta name="theme-color" content="#0d6efd">
    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    
    <!-- Custom page styles -->
    <% if (typeof pageStyles !== 'undefined' && pageStyles) { %>
        <%- pageStyles %>
    <% } %>
</head>
<body class="<%- bodyClass || '' %>">
    <!-- Navigation (only show if not login page) -->
    <% if (!hideNavigation) { %>
        <%- include('partials/navigation') %>
    <% } %>

    <!-- Page Header (optional) -->
    <% if (typeof pageHeader !== 'undefined') { %>
        <div class="page-header">
            <%- pageHeader %>
        </div>
    <% } %>

    <!-- Main Content -->
    <main class="<%- mainClass || 'container mt-4' %>">
        <!-- Breadcrumb (optional) -->
        <% if (typeof breadcrumb !== 'undefined' && breadcrumb && Array.isArray(breadcrumb) && breadcrumb.length > 0) { %>
            <%- include('partials/breadcrumb', { breadcrumb: breadcrumb }) %>
        <% } %>

        <!-- Page Content -->
        <%- body %>
    </main>

    <!-- Footer (optional) -->
    <% if (showFooter) { %>
        <%- include('partials/footer') %>
    <% } %>

    <!-- JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom page scripts -->
    <% if (typeof pageScripts !== 'undefined' && pageScripts) { %>
        <%- pageScripts %>
    <% } %>
    
    <!-- Global scripts -->
    <script src="/js/common.js"></script>
</body>
</html>
