<style>
body {
    padding: 0 !important;
}

</style>
<!-- Login Content (no layout needed, uses full page) -->
<div class="row h-100">
    <div class="col-md-6 d-none d-md-block login-bg">
        <div class="overlay">
            <div class="text-center text-white p-5">
                <i class="fas fa-graduation-cap fa-5x mb-4"></i>
                <h2>Smart Learning Advisor</h2>
                <p class="lead">Hệ thống tư vấn học tập thông minh cho sinh viên EIU</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 d-flex align-items-center justify-content-center">
        <div class="login-form-container">
            <div class="text-center mb-4">
                <i class="fas fa-user-graduate fa-3x text-primary mb-3"></i>
                <h3>Đăng nhập</h3>
                <p class="text-muted">Vui lòng đăng nhập để tiếp tục</p>
            </div>
            
            <% if (error) { %>
                <div class="alert alert-danger" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <%= error %>
                </div>
            <% } %>
            
            <form action="/login" method="POST" data-loading>
                <div class="mb-3">
                    <label for="studentId" class="form-label">
                        <i class="fas fa-id-card me-2"></i>ID Sinh viên
                    </label>
                    <input type="text" class="form-control" id="studentId" name="studentId" required>
                </div>
                
                <div class="mb-3">
                    <label for="password" class="form-label">
                        <i class="fas fa-lock me-2"></i>Mật khẩu
                    </label>
                    <input type="password" class="form-control" id="password" name="password" required>
                </div>
                
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                </button>
            </form>
            <div class="d-flex align-items-center my-3">
    <hr class="flex-grow-1">
    <span class="px-2 text-muted small">hoặc</span>
    <hr class="flex-grow-1">
</div>

<a href="/auth/google" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
    <svg width="18" height="18" viewBox="0 0 48 48">
        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
    </svg>
    Đăng nhập bằng Google (EIU)
</a>

<%
const errMap = {
    google: 'Đăng nhập Google thất bại.',
    no_email: 'Không lấy được email từ Google.',
    eiu_auth: 'Tài khoản Google này chưa được liên kết với AAO.',
    eiu_error: 'Lỗi kết nối hệ thống EIU.'
};
const urlErr = errMap[query && query.err];
%>
<% if (urlErr) { %>
    <div class="alert alert-danger mt-3">
        <i class="fas fa-exclamation-triangle me-2"></i><%= urlErr %>
    </div>
<% } %>
            <div class="text-center mt-4">
                <small class="text-muted">
                    © 2025 EIU Smart Learning Advisor
                </small>
            </div>
        </div>
    </div>
</div>